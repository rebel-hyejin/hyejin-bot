# daeyeon-bot — environment overrides
#
# Copy to `.env` and fill in. The bot reads `.env` ONLY in dev/CLI invocations;
# the daemon entrypoint (`deploy/launchd/entrypoint.sh` or systemd `LoadCredential`)
# does NOT read `.env` — it pulls secrets from Keychain (Mac) or 0600 file (Linux).
#
# All keys are documented in `config.example.toml`. This file lets you override
# specific values without editing the TOML config.

# Path to the local config file. Default: ./config.toml
# DAEYEON_BOT_CONFIG=./config.toml

# Override state directory. Default: ~/.daeyeon-bot
# DAEYEON_BOT__RUNTIME__STATE_DIR=~/.daeyeon-bot

# Logging
# DAEYEON_BOT__LOGGING__LEVEL=DEBUG
# DAEYEON_BOT__LOGGING__FORMAT=console

# DEV ONLY: bypass Keychain and pass token via env. Daemon refuses unless --insecure-env.
# CLAUDE_CODE_OAUTH_TOKEN=
